BOT_TOKEN=your_bot_token
OWNER_TELEGRAM_ID=your_telegram_id
TELEGRAM_API_ID=your_telegram_api_id
TELEGRAM_API_HASH=your_telegram_api_hash

DATABASE_URL=sqlite:///./data/cex_restore.db
DRY_RUN=True
LOG_LEVEL=INFO
TZ=Europe/Moscow
SESSIONS_DIR=sessions
LOGS_DIR=logs
BACKUP_DIR=backups
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
SCHEDULER_CHECK_INTERVAL_SECONDS=60

# 30 minutes by default. Set to 0 to disable background proxy monitoring.
PROXY_MONITOR_INTERVAL_SECONDS=1800

# Central account orchestration limits. Keep client/login/batch values in the
# documented safe range; higher values increase Telegram flood-risk.
ORCHESTRATOR_MAX_CLIENTS=5
ORCHESTRATOR_LOGIN_CONCURRENCY=3
ORCHESTRATOR_HEALTH_BATCH_SIZE=4
ORCHESTRATOR_GLOBAL_DELAY_SECONDS=0.25
ORCHESTRATOR_ACCOUNT_DELAY_SECONDS=1.0
ORCHESTRATOR_LOGIN_MAX_RETRIES=3

# Self-regulating control loop. Interval is intentionally restricted to 10–30s.
AUTOPILOT_INTERVAL_SECONDS=15
AUTOPILOT_QUEUE_THRESHOLD=20
AUTOPILOT_RECOVERY_COOLDOWN_SECONDS=300
AUTOPILOT_HEALTHY_CLIENTS=5
